rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ===== HELPER FUNCTIONS =====
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user owns the file
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Validate image file types
    function isValidImageType() {
      return resource.contentType.matches('image/.*') &&
             resource.contentType in ['image/jpeg', 'image/png', 'image/jpg', 'image/webp'];
    }
    
    // Validate video file types
    function isValidVideoType() {
      return resource.contentType.matches('video/.*') &&
             resource.contentType in ['video/mp4', 'video/avi', 'video/mov', 'video/webm'];
    }
    
    // Validate audio file types
    function isValidAudioType() {
      return resource.contentType.matches('audio/.*') &&
             resource.contentType in ['audio/mp3', 'audio/wav', 'audio/aac', 'audio/ogg', 'audio/webm'];
    }
    
    // Validate document file types
    function isValidDocumentType() {
      return resource.contentType in [
        'application/pdf',
        'application/msword',
        'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
        'application/vnd.ms-excel',
        'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
        'application/vnd.ms-powerpoint',
        'application/vnd.openxmlformats-officedocument.presentationml.presentation',
        'text/plain'
      ];
    }
    
    // Check file size limits
    function isValidFileSize(maxSizeInMB) {
      return resource.size <= maxSizeInMB * 1024 * 1024;
    }
    
    // ===== PROFILE PICTURES =====
    match /profile_pictures/{userId}/{fileName} {
      // Users can read any profile picture (subject to privacy settings in app)
      allow read: if isAuthenticated();
      
      // Users can only upload to their own profile picture folder
      allow write: if isOwner(userId) &&
                      isValidImageType() &&
                      isValidFileSize(5); // 5MB limit for profile pictures
      
      // Allow deletion of own profile pictures
      allow delete: if isOwner(userId);
    }
    
    // ===== CHAT MEDIA =====
    match /chat_media/{chatId}/{userId}/{fileName} {
      // Only allow reading if user has access to the chat
      // Note: This requires validation in the app since we can't access Firestore here
      allow read: if isAuthenticated();
      
      // Users can upload media to chats they participate in
      allow write: if isOwner(userId) &&
                      (isValidImageType() && isValidFileSize(10) ||  // 10MB for images
                       isValidVideoType() && isValidFileSize(50) ||  // 50MB for videos
                       isValidAudioType() && isValidFileSize(10) ||  // 10MB for audio
                       isValidDocumentType() && isValidFileSize(20)); // 20MB for documents
      
      // Allow deletion by the uploader
      allow delete: if isOwner(userId);
    }
    
    // ===== STATUS MEDIA =====
    match /status_media/{userId}/{fileName} {
      // Users can read status media from non-blocked users
      allow read: if isAuthenticated();
      
      // Users can only upload to their own status folder
      allow write: if isOwner(userId) &&
                      (isValidImageType() && isValidFileSize(10) ||  // 10MB for images
                       isValidVideoType() && isValidFileSize(30)) &&  // 30MB for videos
                      // Status media should be temporary
                      resource.timeCreated > request.time - duration.value(1, 'd'); // 1 day expiry
      
      // Allow deletion of own status media
      allow delete: if isOwner(userId);
    }
    
    // ===== CALL RECORDINGS (if implemented) =====
    match /call_recordings/{callId}/{fileName} {
      // Strict access control for call recordings
      allow read: if false; // Disable for privacy
      allow write: if false; // Disable call recording uploads
      allow delete: if false;
    }
    
    // ===== TEMPORARY UPLOADS =====
    match /temp_uploads/{userId}/{fileName} {
      // Temporary storage for file processing
      allow read, write: if isOwner(userId) &&
                            isValidFileSize(100) && // 100MB temp limit
                            // Auto-expire temp files after 1 hour
                            resource.timeCreated > request.time - duration.value(1, 'h');
      
      // Allow deletion of own temp files
      allow delete: if isOwner(userId);
    }
    
    // ===== BACKUP DATA =====
    match /backups/{userId}/{fileName} {
      // Users can backup and restore their own data
      allow read, write: if isOwner(userId) &&
                            resource.contentType == 'application/json' &&
                            isValidFileSize(50); // 50MB backup limit
      
      // Allow deletion of own backups
      allow delete: if isOwner(userId);
    }
    
    // ===== APP ASSETS (read-only) =====
    match /app_assets/{fileName} {
      // Public read access for app assets
      allow read: if true;
      // No write access to app assets
      allow write: if false;
    }
    
    // ===== THUMBNAILS =====
    match /thumbnails/{path=**} {
      // Allow read access to thumbnails
      allow read: if isAuthenticated();
      // Thumbnails are generated by Cloud Functions, no direct upload
      allow write: if false;
      // No deletion of thumbnails
      allow delete: if false;
    }
    
    // ===== DEFAULT DENY =====
    // Deny access to any other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}