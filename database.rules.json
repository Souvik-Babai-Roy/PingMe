{
  "rules": {
    // Helper function to check if user is authenticated
    ".read": false,
    ".write": false,
    
    // Chats - Direct messaging between users
    "chats": {
      "$chatId": {
        // Users can read/write chats they participate in
        ".read": "auth != null && root.child('chats').child($chatId).child('participants').child(auth.uid).exists()",
        ".write": "auth != null && root.child('chats').child($chatId).child('participants').child(auth.uid).exists()",
        
        // Chat metadata validation
        "id": {
          ".validate": "newData.isString() && newData.val() === $chatId"
        },
        "participants": {
          "$userId": {
            ".validate": "newData.isBoolean() && newData.val() === true"
          }
        },
        "lastMessage": {
          ".validate": "newData.isString()"
        },
        "lastMessageTimestamp": {
          ".validate": "newData.isNumber()"
        },
        "lastMessageSenderId": {
          ".validate": "newData.isString()"
        },
        "lastMessageType": {
          ".validate": "newData.isString()"
        },
        "lastMessageId": {
          ".validate": "newData.isString()"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "type": {
          ".validate": "newData.val() === 'direct' || newData.val() === 'group'"
        },
        "isActive": {
          ".validate": "newData.isBoolean()"
        }
      }
    },
    
    // Messages - Chat messages between users
    "messages": {
      "$chatId": {
        // Users can read messages from chats they participate in
        ".read": "auth != null && root.child('chats').child($chatId).child('participants').child(auth.uid).exists()",
        
        "$messageId": {
          // Users can write messages to chats they participate in
          ".write": "auth != null && root.child('chats').child($chatId).child('participants').child(auth.uid).exists() && (newData.child('senderId').val() === auth.uid || data.child('senderId').val() === auth.uid)",
          
          // Message structure validation
          "id": {
            ".validate": "newData.isString() && newData.val() === $messageId"
          },
          "senderId": {
            ".validate": "newData.isString()"
          },
          "text": {
            ".validate": "newData.isString() && newData.val().length <= 4000"
          },
          "timestamp": {
            ".validate": "newData.isNumber() && newData.val() <= now + 60000"
          },
          "status": {
            ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 4"
          },
          "type": {
            ".validate": "newData.isString()"
          },
          // Delivery and read receipts tracking
          "deliveredTo": {
            "$userId": {
              ".validate": "newData.isNumber()"
            }
          },
          "readBy": {
            "$userId": {
              ".validate": "newData.isNumber()"
            }
          },
          // Media attachments with Cloudinary support
          "imageUrl": {
            ".validate": "newData.isString()"
          },
          "videoUrl": {
            ".validate": "newData.isString()"
          },
          "audioUrl": {
            ".validate": "newData.isString()"
          },
          "documentUrl": {
            ".validate": "newData.isString()"
          },
          "thumbnailUrl": {
            ".validate": "newData.isString()"
          },
          "fileName": {
            ".validate": "newData.isString()"
          },
          "fileSize": {
            ".validate": "newData.isNumber()"
          },
          "duration": {
            ".validate": "newData.isNumber()"
          },
          "cloudinaryPublicId": {
            ".validate": "newData.isString()"
          },
          "cloudinaryUrl": {
            ".validate": "newData.isString()"
          },
          "width": {
            ".validate": "newData.isNumber()"
          },
          "height": {
            ".validate": "newData.isNumber()"
          },
          // Message sharing and forwarding
          "isForwarded": {
            ".validate": "newData.isBoolean()"
          },
          "originalSenderId": {
            ".validate": "newData.isString()"
          },
          "forwardCount": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },
          "sharedFrom": {
            ".validate": "newData.isString()"
          },
          // Message reactions
          "reactions": {
            "$userId": {
              ".validate": "newData.isString()"
            }
          },
          // Message editing
          "editedAt": {
            ".validate": "newData.isNumber()"
          },
          "isEdited": {
            ".validate": "newData.isBoolean()"
          }
        }
      }
    },
    
    // User chats - Track which chats each user participates in
    "user_chats": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId",
        
        "$chatId": {
          ".validate": "newData.isBoolean() || newData.hasChildren()",
          "isActive": {
            ".validate": "newData.isBoolean()"
          },
          "unreadCount": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },
          "lastReadMessageId": {
            ".validate": "newData.isString()"
          },
          "lastReadTimestamp": {
            ".validate": "newData.isNumber()"
          },
          "isMuted": {
            ".validate": "newData.isBoolean()"
          },
          "muteUntil": {
            ".validate": "newData.isNumber()"
          }
        }
      }
    },
    
    // Typing indicators - Real-time typing status
    "typing": {
      "$chatId": {
        ".read": "auth != null && root.child('chats').child($chatId).child('participants').child(auth.uid).exists()",
        
        "$userId": {
          ".write": "auth != null && auth.uid === $userId && root.child('chats').child($chatId).child('participants').child(auth.uid).exists()",
          ".validate": "newData.isNumber()"
        }
      }
    },
    
    // User presence - Online/offline status with privacy controls
    "presence": {
      "$userId": {
        // Only friends can read presence based on privacy settings
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $userId",
        
        "isOnline": {
          ".validate": "newData.isBoolean()"
        },
        "online": {
          ".validate": "newData.isBoolean()"
        },
        "lastSeen": {
          ".validate": "newData.isNumber()"
        },
        "showLastSeen": {
          ".validate": "newData.isBoolean()"
        }
      }
    },
    
    // Blocked users - Track who has blocked whom
    "blocked_users": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId",
        
        "$blockedUserId": {
          ".validate": "newData.isBoolean() || newData.isNumber()"
        }
      }
    },
    
    // Broadcasts - Group messaging
    "broadcasts": {
      "$broadcastId": {
        ".read": "auth != null && (data.child('creatorId').val() === auth.uid || data.child('members').child(auth.uid).exists())",
        ".write": "auth != null && (data.child('creatorId').val() === auth.uid || newData.child('creatorId').val() === auth.uid)",
        
        "id": {
          ".validate": "newData.isString()"
        },
        "name": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 100"
        },
        "description": {
          ".validate": "newData.isString() && newData.val().length <= 500"
        },
        "creatorId": {
          ".validate": "newData.isString()"
        },
        "members": {
          ".validate": "newData.hasChildren()",
          "$memberId": {
            ".validate": "newData.isBoolean()"
          }
        },
        "admins": {
          "$adminId": {
            ".validate": "newData.isBoolean()"
          }
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "lastMessage": {
          ".validate": "newData.isString()"
        },
        "lastMessageTimestamp": {
          ".validate": "newData.isNumber()"
        },
        "messageCount": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      }
    },
    
    // Broadcast messages
    "broadcast_messages": {
      "$broadcastId": {
        ".read": "auth != null && (root.child('broadcasts').child($broadcastId).child('members').child(auth.uid).exists() || root.child('broadcasts').child($broadcastId).child('creatorId').val() === auth.uid)",
        
        "$messageId": {
          ".write": "auth != null && (root.child('broadcasts').child($broadcastId).child('creatorId').val() === auth.uid || root.child('broadcasts').child($broadcastId).child('admins').child(auth.uid).exists()) && newData.child('senderId').val() === auth.uid",
          
          "id": {
            ".validate": "newData.isString()"
          },
          "senderId": {
            ".validate": "newData.isString() && newData.val() === auth.uid"
          },
          "text": {
            ".validate": "newData.isString() && newData.val().length <= 4000"
          },
          "timestamp": {
            ".validate": "newData.isNumber() && newData.val() <= now + 60000"
          },
          "type": {
            ".validate": "newData.isString()"
          },
          "deliveredTo": {
            "$userId": {
              ".validate": "newData.isNumber()"
            }
          },
          "readBy": {
            "$userId": {
              ".validate": "newData.isNumber()"
            }
          }
        }
      }
    },
    
    // User broadcasts - Track which broadcasts each user belongs to
    "user_broadcasts": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId",
        
        "$broadcastId": {
          ".validate": "newData.isBoolean()",
          "joinedAt": {
            ".validate": "newData.isNumber()"
          },
          "unreadCount": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },
          "lastReadMessageId": {
            ".validate": "newData.isString()"
          }
        }
      }
    },
    
    // FCM tokens for push notifications
    "fcm_tokens": {
      "$userId": {
        ".read": false,
        ".write": "auth != null && auth.uid === $userId",
        ".validate": "newData.isString()"
      }
    },
    
    // User settings stored in Realtime Database
    "user_settings": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId",
        
        "notifications": {
          ".validate": "newData.isBoolean()"
        },
        "soundEnabled": {
          ".validate": "newData.isBoolean()"
        },
        "vibrationEnabled": {
          ".validate": "newData.isBoolean()"
        },
        "readReceipts": {
          ".validate": "newData.isBoolean()"
        },
        "lastSeenPrivacy": {
          ".validate": "newData.val() === 'everyone' || newData.val() === 'friends' || newData.val() === 'nobody'"
        },
        "profilePhotoPrivacy": {
          ".validate": "newData.val() === 'everyone' || newData.val() === 'friends' || newData.val() === 'nobody'"
        },
        "aboutPrivacy": {
          ".validate": "newData.val() === 'everyone' || newData.val() === 'friends' || newData.val() === 'nobody'"
        }
      }
    },
    
    // Message search index (for better search performance)
    "message_search": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId",
        
        "$chatId": {
          "$messageId": {
            "keywords": {
              ".validate": "newData.isString()"
            },
            "timestamp": {
              ".validate": "newData.isNumber()"
            }
          }
        }
      }
    },
    
    // Shared messages tracking
    "shared_messages": {
      "$shareId": {
        ".read": "auth != null && (data.child('senderId').val() === auth.uid || data.child('recipients').child(auth.uid).exists())",
        ".write": "auth != null && (newData.child('senderId').val() === auth.uid || data.child('senderId').val() === auth.uid)",
        
        "id": {
          ".validate": "newData.isString()"
        },
        "senderId": {
          ".validate": "newData.isString()"
        },
        "originalMessageId": {
          ".validate": "newData.isString()"
        },
        "originalChatId": {
          ".validate": "newData.isString()"
        },
        "recipients": {
          "$userId": {
            ".validate": "newData.isBoolean()"
          }
        },
        "message": {
          ".validate": "newData.hasChildren()"
        },
        "timestamp": {
          ".validate": "newData.isNumber()"
        },
        "deliveryStatus": {
          "$userId": {
            ".validate": "newData.isString()"
          }
        }
      }
    },
    
    // Call logs and video call data
    "calls": {
      "$callId": {
        ".read": "auth != null && (data.child('callerId').val() === auth.uid || data.child('receiverId').val() === auth.uid)",
        ".write": "auth != null && (newData.child('callerId').val() === auth.uid || newData.child('receiverId').val() === auth.uid || data.child('callerId').val() === auth.uid || data.child('receiverId').val() === auth.uid)",
        
        "callerId": {
          ".validate": "newData.isString()"
        },
        "receiverId": {
          ".validate": "newData.isString()"
        },
        "type": {
          ".validate": "newData.val() === 'voice' || newData.val() === 'video'"
        },
        "status": {
          ".validate": "newData.val() === 'ringing' || newData.val() === 'accepted' || newData.val() === 'declined' || newData.val() === 'missed' || newData.val() === 'ended'"
        },
        "timestamp": {
          ".validate": "newData.isNumber()"
        },
        "duration": {
          ".validate": "newData.isNumber()"
        },
        "endedBy": {
          ".validate": "newData.isString()"
        }
      }
    },
    
    // System notifications and announcements
    "system_notifications": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": false,
        
        "$notificationId": {
          "title": {
            ".validate": "data.isString()"
          },
          "body": {
            ".validate": "data.isString()"
          },
          "timestamp": {
            ".validate": "data.isNumber()"
          },
          "read": {
            ".write": "auth != null && auth.uid === $userId",
            ".validate": "newData.isBoolean()"
          },
          "type": {
            ".validate": "data.isString()"
          },
          "data": {
            ".validate": "data.hasChildren()"
          }
        }
      }
    }
  }
}