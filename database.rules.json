{
  "rules": {
    // Helper function to check if user is authenticated
    ".read": false,
    ".write": false,
    
    // Chats - Direct messaging between users
    "chats": {
      "$chatId": {
        // Users can read/write chats they participate in
        ".read": "auth != null && (data.child('participants').child(auth.uid).exists())",
        ".write": "auth != null && (data.child('participants').child(auth.uid).exists() || newData.child('participants').child(auth.uid).exists())",
        
        // Chat metadata
        "id": {
          ".validate": "newData.isString() && newData.val() === $chatId"
        },
        "participants": {
          "$userId": {
            ".validate": "newData.isBoolean() && newData.val() === true"
          }
        },
        "lastMessage": {
          ".validate": "newData.isString()"
        },
        "lastMessageTimestamp": {
          ".validate": "newData.isNumber()"
        },
        "lastMessageSenderId": {
          ".validate": "newData.isString()"
        },
        "lastMessageType": {
          ".validate": "newData.isString()"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "type": {
          ".validate": "newData.val() === 'direct' || newData.val() === 'group'"
        },
        "isActive": {
          ".validate": "newData.isBoolean()"
        }
      }
    },
    
    // Messages - Chat messages between users
    "messages": {
      "$chatId": {
        // Users can read messages from chats they participate in
        ".read": "auth != null && root.child('chats').child($chatId).child('participants').child(auth.uid).exists()",
        
        "$messageId": {
          // Users can write messages to chats they participate in
          ".write": "auth != null && root.child('chats').child($chatId).child('participants').child(auth.uid).exists() && newData.child('senderId').val() === auth.uid",
          
          // Message structure validation
          "id": {
            ".validate": "newData.isString() && newData.val() === $messageId"
          },
          "senderId": {
            ".validate": "newData.isString() && newData.val() === auth.uid"
          },
          "text": {
            ".validate": "newData.isString() && newData.val().length <= 4000"
          },
          "timestamp": {
            ".validate": "newData.isNumber() && newData.val() <= now + 60000"
          },
          "status": {
            ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 4"
          },
          "type": {
            ".validate": "newData.isString()"
          },
          // Media attachments (optional)
          "imageUrl": {
            ".validate": "newData.isString()"
          },
          "videoUrl": {
            ".validate": "newData.isString()"
          },
          "audioUrl": {
            ".validate": "newData.isString()"
          },
          "documentUrl": {
            ".validate": "newData.isString()"
          },
          "thumbnailUrl": {
            ".validate": "newData.isString()"
          }
        }
      }
    },
    
    // User chats - Track which chats each user participates in
    "user_chats": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId",
        
        "$chatId": {
          ".validate": "newData.isBoolean()"
        }
      }
    },
    
    // Typing indicators - Real-time typing status
    "typing": {
      "$chatId": {
        ".read": "auth != null && root.child('chats').child($chatId).child('participants').child(auth.uid).exists()",
        
        "$userId": {
          ".write": "auth != null && auth.uid === $userId && root.child('chats').child($chatId).child('participants').child(auth.uid).exists()",
          ".validate": "newData.isNumber()"
        }
      }
    },
    
    // User presence - Online/offline status
    "presence": {
      "$userId": {
        ".read": true,  // Anyone can read presence (privacy controlled at app level)
        ".write": "auth != null && auth.uid === $userId",
        
        "online": {
          ".validate": "newData.isBoolean()"
        },
        "lastSeen": {
          ".validate": "newData.isNumber()"
        }
      }
    },
    
    // Blocked users - Track who has blocked whom
    "blocked_users": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId",
        
        "$blockedUserId": {
          ".validate": "newData.isNumber()"  // Timestamp of when blocked
        }
      }
    },
    
    // Cleared chats - Track when users cleared their chat history
    "cleared_chats": {
      "$chatId": {
        "$userId": {
          ".read": "auth != null && auth.uid === $userId",
          ".write": "auth != null && auth.uid === $userId",
          ".validate": "newData.isNumber()"  // Timestamp of when cleared
        }
      }
    },
    
    // User specific chat data - For one-sided operations
    "user_specific_chats": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId",
        
        "$chatId": {
          "lastMessage": {
            ".validate": "newData.isString()"
          },
          "lastMessageType": {
            ".validate": "newData.isString()"
          },
          "clearedAt": {
            ".validate": "newData.isNumber()"
          }
        }
      }
    },
    
    // FCM tokens for push notifications
    "fcm_tokens": {
      "$userId": {
        ".read": false,  // Only server should read tokens
        ".write": "auth != null && auth.uid === $userId",
        ".validate": "newData.isString()"
      }
    },
    
    // User settings stored in Realtime Database
    "user_settings": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId",
        
        "notifications": {
          ".validate": "newData.isBoolean()"
        },
        "soundEnabled": {
          ".validate": "newData.isBoolean()"
        },
        "vibrationEnabled": {
          ".validate": "newData.isBoolean()"
        }
      }
    },
    
    // Call logs and video call data
    "calls": {
      "$callId": {
        ".read": "auth != null && (data.child('callerId').val() === auth.uid || data.child('receiverId').val() === auth.uid)",
        ".write": "auth != null && (newData.child('callerId').val() === auth.uid || newData.child('receiverId').val() === auth.uid)",
        
        "callerId": {
          ".validate": "newData.isString()"
        },
        "receiverId": {
          ".validate": "newData.isString()"
        },
        "type": {
          ".validate": "newData.val() === 'voice' || newData.val() === 'video'"
        },
        "status": {
          ".validate": "newData.val() === 'ringing' || newData.val() === 'accepted' || newData.val() === 'declined' || newData.val() === 'missed' || newData.val() === 'ended'"
        },
        "timestamp": {
          ".validate": "newData.isNumber()"
        },
        "duration": {
          ".validate": "newData.isNumber()"
        }
      }
    },
    
    // Group chats (for future implementation)
    "groups": {
      "$groupId": {
        ".read": "auth != null && data.child('members').child(auth.uid).exists()",
        ".write": "auth != null && (data.child('members').child(auth.uid).exists() || data.child('admins').child(auth.uid).exists())",
        
        "name": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 50"
        },
        "description": {
          ".validate": "newData.isString() && newData.val().length <= 500"
        },
        "imageUrl": {
          ".validate": "newData.isString()"
        },
        "createdBy": {
          ".validate": "newData.isString()"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "members": {
          "$memberId": {
            ".validate": "newData.isBoolean()"
          }
        },
        "admins": {
          "$adminId": {
            ".validate": "newData.isBoolean()"
          }
        }
      }
    },
    
    // System notifications and announcements
    "system_notifications": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": false,  // Only server can write system notifications
        
        "$notificationId": {
          "title": {
            ".validate": "data.isString()"
          },
          "body": {
            ".validate": "data.isString()"
          },
          "timestamp": {
            ".validate": "data.isNumber()"
          },
          "read": {
            ".write": "auth != null && auth.uid === $userId",
            ".validate": "newData.isBoolean()"
          }
        }
      }
    }
  }
}