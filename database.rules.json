{
  "rules": {
    ".read": false,
    ".write": false,

    "chats": {
      "$chatId": {
        ".read": "auth != null && root.child('chats').child($chatId).child('participants').child(auth.uid).exists()",
        ".write": "auth != null && (root.child('chats').child($chatId).child('participants').child(auth.uid).exists() || !data.exists())",
        "id": { ".validate": "newData.isString() && newData.val() == $chatId" },
        "participants": {
          "$userId": { ".validate": "newData.isBoolean() && newData.val() == true" }
        },
        "lastMessage": { ".validate": "newData.isString() && newData.val().length <= 1000" },
        "lastMessageTimestamp": { ".validate": "newData.isNumber() && newData.val() <= now" },
        "lastMessageSenderId": { ".validate": "newData.isString() && newData.val().length > 0" },
        "lastMessageType": { ".validate": "newData.isString() && newData.val().matches(/^(text|image|video|audio|document|file|empty_chat)$/)" },
        "lastMessageId": { ".validate": "newData.isString() && newData.val().length > 0" },
        "createdAt": { ".validate": "newData.isNumber() && newData.val() <= now" },
        "type": { ".validate": "newData.val() == 'direct' || newData.val() == 'group'" },
        "isActive": { ".validate": "newData.isBoolean()" },
        "name": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length >= 1 && newData.val().length <= 100)" },
        "description": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 500)" },
        "createdBy": { ".validate": "!newData.exists() || newData.isString()" },
        "otherUser": { ".validate": "!newData.exists() || newData.hasChildren()" }
      }
    },

    "messages": {
      "$chatId": {
        ".read": "auth != null && root.child('chats').child($chatId).child('participants').child(auth.uid).exists()",
        "$messageId": {
          ".write": "auth != null && root.child('chats').child($chatId).child('participants').child(auth.uid).exists() && (newData.child('senderId').val() == auth.uid || data.child('senderId').val() == auth.uid)",
          "id": { ".validate": "newData.isString() && newData.val() == $messageId" },
          "senderId": { ".validate": "newData.isString() && (newData.val() == auth.uid || data.val() == auth.uid)" },
          "text": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 4000)" },
          "timestamp": { ".validate": "newData.isNumber() && newData.val() <= now + 300000" },
          "status": { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 4" },
          "type": { ".validate": "newData.isString() && newData.val().matches(/^(text|image|video|audio|document|file|location|contact)$/)" },
          "deliveredTo": {
            "$userId": { ".validate": "newData.isNumber() && newData.val() <= now" }
          },
          "readBy": {
            "$userId": { ".validate": "newData.isNumber() && newData.val() <= now" }
          },
          "imageUrl": { ".validate": "!newData.exists() || newData.isString()" },
          "videoUrl": { ".validate": "!newData.exists() || newData.isString()" },
          "audioUrl": { ".validate": "!newData.exists() || newData.isString()" },
          "documentUrl": { ".validate": "!newData.exists() || newData.isString()" },
          "fileUrl": { ".validate": "!newData.exists() || newData.isString()" },
          "thumbnailUrl": { ".validate": "!newData.exists() || newData.isString()" },
          "fileName": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 255)" },
          "fileSize": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)" },
          "duration": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)" },
          "cloudinaryPublicId": { ".validate": "!newData.exists() || newData.isString()" },
          "cloudinaryUrl": { ".validate": "!newData.exists() || newData.isString()" },
          "width": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() > 0)" },
          "height": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() > 0)" },
          "isForwarded": { ".validate": "!newData.exists() || newData.isBoolean()" },
          "originalSenderId": { ".validate": "!newData.exists() || newData.isString()" },
          "forwardCount": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 5)" },
          "sharedFrom": { ".validate": "!newData.exists() || newData.isString()" },
          "reactions": {
            "$userId": { ".validate": "newData.isString() && newData.val().length <= 10" }
          },
          "editedAt": { ".validate": "!newData.exists() || newData.isNumber()" },
          "isEdited": { ".validate": "!newData.exists() || newData.isBoolean()" },
          "replyTo": { ".validate": "!newData.exists() || newData.isString()" },
          "deletedFor": {
            "$userId": { ".validate": "newData.isNumber() && newData.val() <= now" }
          },
          "deletedAt": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() <= now)" },
          "deletedBy": { ".validate": "!newData.exists() || newData.isString()" },
          "isDeletedForMe": { ".validate": "!newData.exists() || newData.isBoolean()" },
          "isDeletedForEveryone": { ".validate": "!newData.exists() || newData.isBoolean()" },
          "action": { ".validate": "!newData.exists() || newData.val().matches(/^(none|reply|forward|edit|delete_for_me|delete_for_everyone)$/)" },
          "replyToMessageId": { ".validate": "!newData.exists() || newData.isString()" },
          "originalMessageId": { ".validate": "!newData.exists() || newData.isString()" },
          "editedText": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 4000)" },
          "isReply": { ".validate": "!newData.exists() || newData.isBoolean()" },
          "clearedFor": {
            "$userId": { ".validate": "newData.isNumber() && newData.val() <= now" }
          },
          "isEncrypted": { ".validate": "!newData.exists() || newData.isBoolean()" },
          "encryptedContent": { ".validate": "!newData.exists() || newData.isString()" }
        }
      }
    },

    "user_chats": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && auth.uid == $userId",
        "$chatId": {
          ".validate": "newData.isBoolean() || newData.hasChildren()",
          "isActive": { ".validate": "!newData.exists() || newData.isBoolean()" },
          "unreadCount": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)" },
          "lastReadMessageId": { ".validate": "!newData.exists() || newData.isString()" },
          "lastReadTimestamp": { ".validate": "!newData.exists() || newData.isNumber()" },
          "isMuted": { ".validate": "!newData.exists() || newData.isBoolean()" },
          "muteUntil": { ".validate": "!newData.exists() || newData.isNumber()" },
          "pinnedAt": { ".validate": "!newData.exists() || newData.isNumber()" },
          "archived": { ".validate": "!newData.exists() || newData.isBoolean()" },
          "clearedAt": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() <= now)" },
          "deletedAt": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() <= now)" },
          "isDeleted": { ".validate": "!newData.exists() || newData.isBoolean()" }
        }
      }
    },

    "typing": {
      "$chatId": {
        ".read": "auth != null && root.child('chats').child($chatId).child('participants').child(auth.uid).exists()",
        "$userId": {
          ".write": "auth != null && auth.uid == $userId && root.child('chats').child($chatId).child('participants').child(auth.uid).exists()",
          ".validate": "newData.isNumber() && newData.val() >= now - 10000 && newData.val() <= now + 10000"
        }
      }
    },

    "presence": {
      "$userId": {
        ".read": "auth != null && (auth.uid == $userId || root.child('users').child($userId).child('privacy').child('lastSeen').val() != 'nobody')",
        ".write": "auth != null && auth.uid == $userId",
        "isOnline": { ".validate": "newData.isBoolean()" },
        "lastSeen": { ".validate": "newData.isNumber() && newData.val() <= now + 60000" }
      }
    },

    "blocked_users": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && auth.uid == $userId",
        "$blockedUserId": { ".validate": "newData.isBoolean() && newData.val() == true && $blockedUserId != auth.uid" }
      }
    },

    "users": {
      "$userId": {
        ".read": "auth != null && (auth.uid == $userId || root.child('users').child($userId).child('privacy').child('profilePhoto').val() != 'nobody')",
        ".write": "auth != null && auth.uid == $userId",
        "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50 && newData.val().matches(/^[a-zA-Z0-9 ._-]+$/)" },
        "email": { ".validate": "newData.isString() && newData.val().matches(/^[A-Za-z0-9+_.-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$/)" },
        "phoneNumber": { ".validate": "!newData.exists() || (newData.isString() && newData.val().matches(/^\\+?[1-9]\\d{1,14}$/))" },
        "fcmToken": { ".validate": "!newData.exists() || newData.isString()" },
        "imageUrl": { ".validate": "!newData.exists() || newData.isString()" },
        "createdAt": { ".validate": "newData.isNumber() && newData.val() <= now" },
        "about": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 200)" },
        "isOnline": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "lastSeen": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() <= now)" },
        "joinedAt": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() <= now)" },
        "isBlocked": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "friendshipStatus": { ".validate": "!newData.exists() || newData.val().matches(/^(none|friend|blocked|pending)$/)" },
        "personalName": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 50)" },
        "profilePhotoEnabled": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "lastSeenEnabled": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "aboutEnabled": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "readReceiptsEnabled": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "privacy": {
          "lastSeen": { ".validate": "newData.val() == 'everyone' || newData.val() == 'contacts' || newData.val() == 'nobody'" },
          "profilePhoto": { ".validate": "newData.val() == 'everyone' || newData.val() == 'contacts' || newData.val() == 'nobody'" },
          "about": { ".validate": "newData.val() == 'everyone' || newData.val() == 'contacts' || newData.val() == 'nobody'" },
          "readReceipts": { ".validate": "newData.isBoolean()" },
          "groupsAdd": { ".validate": "newData.val() == 'everyone' || newData.val() == 'contacts' || newData.val() == 'nobody'" }
        },
        "contacts": {
          "$contactId": { ".validate": "newData.isBoolean() && newData.val() == true && $contactId != auth.uid" }
        },
        "friends": {
          "$friendId": {
            ".validate": "newData.isBoolean() && newData.val() == true && $friendId != auth.uid",
            "personalName": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 50)" },
            "addedAt": { ".validate": "newData.isNumber() && newData.val() <= now" }
          }
        },
        "settings": {
          "notifications": { ".validate": "!newData.exists() || newData.isBoolean()" },
          "theme": { ".validate": "!newData.exists() || newData.val() == 'light' || newData.val() == 'dark' || newData.val() == 'system'" },
          "language": { ".validate": "!newData.exists() || (newData.isString() && newData.val().matches(/^[a-z]{2}(-[A-Z]{2})?$/))" },
          "chatBackup": { ".validate": "!newData.exists() || newData.isBoolean()" },
          "mediaAutoDownload": { ".validate": "!newData.exists() || newData.isBoolean()" },
          "fontSize": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 12 && newData.val() <= 24)" },
          "soundEnabled": { ".validate": "!newData.exists() || newData.isBoolean()" },
          "vibrationEnabled": { ".validate": "!newData.exists() || newData.isBoolean()" }
        },
        "statuses": {
          "$statusId": {
            ".read": "auth != null && (data.child('userId').val() == auth.uid || root.child('users').child(auth.uid).child('friends').child(data.child('userId').val()).exists())",
            ".write": "auth != null && data.child('userId').val() == auth.uid",
            ".update": "auth != null && (data.child('userId').val() == auth.uid || root.child('users').child(auth.uid).child('friends').child(data.child('userId').val()).exists())",
            ".validate": "newData.hasChildren(['id','timestamp','expiryTime']) && (newData.hasChild('text') || newData.hasChild('mediaUrl'))",
            "id": { ".validate": "newData.isString() && newData.val() == $statusId" },
            "text": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 500)" },
            "mediaUrl": { ".validate": "!newData.exists() || newData.isString()" },
            "mediaType": { ".validate": "!newData.exists() || newData.val() == 'image' || newData.val() == 'video' || newData.val() == 'text'" },
            "timestamp": { ".validate": "newData.isNumber() && newData.val() <= now" },
            "expiryTime": { ".validate": "newData.isNumber() && newData.val() > newData.parent().child('timestamp').val()" },
            "backgroundColor": { ".validate": "!newData.exists() || newData.isString()" },
            "viewers": {
              "$viewerId": { ".validate": "newData.isNumber() && newData.val() <= now" }
            }
          }
        }
      }
    },

    "global_statuses": {
      "$statusId": {
        ".read": "auth != null && (data.child('userId').val() == auth.uid || root.child('users').child(auth.uid).child('friends').child(data.child('userId').val()).exists())",
        ".write": "auth != null && data.child('userId').val() == auth.uid",
        ".update": "auth != null && (data.child('userId').val() == auth.uid || root.child('users').child(auth.uid).child('friends').child(data.child('userId').val()).exists())",
        ".validate": "newData.hasChildren(['id','timestamp','expiryTime']) && (newData.hasChild('text') || newData.hasChild('mediaUrl'))",
        "id": { ".validate": "newData.isString() && newData.val() == $statusId" },
        "userId": { ".validate": "newData.isString() && newData.val() == auth.uid" },
        "text": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 500)" },
        "mediaUrl": { ".validate": "!newData.exists() || newData.isString()" },
        "mediaType": { ".validate": "!newData.exists() || newData.val() == 'image' || newData.val() == 'video' || newData.val() == 'text'" },
        "timestamp": { ".validate": "newData.isNumber() && newData.val() <= now" },
        "expiryTime": { ".validate": "newData.isNumber() && newData.val() > newData.parent().child('timestamp').val()" },
        "backgroundColor": { ".validate": "!newData.exists() || newData.isString()" },
        "viewers": {
          "$viewerId": { ".validate": "newData.isNumber() && newData.val() <= now" }
        }
      }
    },

    "admin_users": {
      "$adminId": {
        ".read": "auth != null && (auth.uid == $adminId || root.child('admin_users').child(auth.uid).child('role').val() == 'admin')",
        ".write": "auth != null && root.child('system_users').child(auth.uid).child('role').val() == 'system'"
      }
    },
    
    "system_users": {
      "$systemId": {
        ".read": "auth != null && auth.uid == $systemId",
        ".write": false
      }
    },
    
    "chat_history": {
      "$chatId": {
        ".read": "auth != null && (root.child('chats').child($chatId).child('participants').child(auth.uid).exists() || root.child('admin_users').child(auth.uid).child('role').val() == 'admin' || root.child('system_users').child(auth.uid).child('role').val() == 'system')",
        ".write": "auth != null && (root.child('chats').child($chatId).child('participants').child(auth.uid).exists() || root.child('admin_users').child(auth.uid).child('role').val() == 'admin' || root.child('system_users').child(auth.uid).child('role').val() == 'system')"
      }
    },

    "groups": {
      "$groupId": {
        ".read": "auth != null && (data.child('createdBy').val() == auth.uid || data.child('members').child(auth.uid).exists())",
        ".write": "auth != null && (data.child('createdBy').val() == auth.uid || data.child('admins').child(auth.uid).exists() || newData.child('createdBy').val() == auth.uid)",
        "id": { ".validate": "newData.isString() && newData.val() == $groupId" },
        "name": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 100" },
        "description": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 500)" },
        "createdBy": { ".validate": "newData.isString()" },
        "imageUrl": { ".validate": "!newData.exists() || newData.isString()" },
        "members": {
          ".validate": "newData.hasChildren()",
          "$memberId": {
            ".validate": "newData.isBoolean() || newData.hasChildren(['joinedAt'])",
            "joinedAt": { ".validate": "newData.isNumber() && newData.val() <= now" },
            "addedBy": { ".validate": "!newData.exists() || newData.isString()" }
          }
        },
        "admins": {
          "$adminId": { ".validate": "newData.isBoolean() && newData.val() == true" }
        },
        "createdAt": { ".validate": "newData.isNumber() && newData.val() <= now" },
        "lastMessage": { ".validate": "!newData.exists() || newData.isString()" },
        "lastMessageTimestamp": { ".validate": "!newData.exists() || newData.isNumber()" },
        "messageCount": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)" },
        "settings": {
          "onlyAdminsCanPost": { ".validate": "!newData.exists() || newData.isBoolean()" },
          "onlyAdminsCanAddMembers": { ".validate": "!newData.exists() || newData.isBoolean()" },
          "onlyAdminsCanEditGroupInfo": { ".validate": "!newData.exists() || newData.isBoolean()" }
        }
      }
    },

    "group_messages": {
      "$groupId": {
        ".read": "auth != null && (root.child('groups').child($groupId).child('members').child(auth.uid).exists() || root.child('groups').child($groupId).child('createdBy').val() == auth.uid)",
        "$messageId": {
          ".write": "auth != null && root.child('groups').child($groupId).child('members').child(auth.uid).exists() && newData.child('senderId').val() == auth.uid",
          "id": { ".validate": "newData.isString() && newData.val() == $messageId" },
          "senderId": { ".validate": "newData.isString() && newData.val() == auth.uid" },
          "text": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 4000)" },
          "timestamp": { ".validate": "newData.isNumber() && newData.val() <= now + 300000" },
          "type": { ".validate": "newData.isString() && newData.val().matches(/^(text|image|video|audio|document|file|system)$/)" },
          "deliveredTo": {
            "$userId": { ".validate": "newData.isNumber() && newData.val() <= now" }
          },
          "readBy": {
            "$userId": { ".validate": "newData.isNumber() && newData.val() <= now" }
          }
        }
      }
    },

    "user_groups": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && auth.uid == $userId",
        "$groupId": {
          ".validate": "newData.isBoolean() || newData.hasChildren()",
          "joinedAt": { ".validate": "!newData.exists() || newData.isNumber()" },
          "unreadCount": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)" },
          "lastReadMessageId": { ".validate": "!newData.exists() || newData.isString()" },
          "isMuted": { ".validate": "!newData.exists() || newData.isBoolean()" },
          "role": { ".validate": "!newData.exists() || newData.val() == 'member' || newData.val() == 'admin' || newData.val() == 'owner'" }
        }
      }
    },

    "calls": {
      "$callId": {
        ".read": "auth != null && (data.child('callerId').val() == auth.uid || data.child('receiverId').val() == auth.uid)",
        ".write": "auth != null && (newData.child('callerId').val() == auth.uid || newData.child('receiverId').val() == auth.uid || data.child('callerId').val() == auth.uid || data.child('receiverId').val() == auth.uid)",
        "callerId": { ".validate": "newData.isString() && (newData.val() == auth.uid || data.val() == auth.uid)" },
        "receiverId": { ".validate": "newData.isString() && (newData.val() != auth.uid || data.val() != auth.uid)" },
        "type": { ".validate": "newData.val() == 'voice' || newData.val() == 'video'" },
        "status": { ".validate": "newData.val() == 'ringing' || newData.val() == 'accepted' || newData.val() == 'declined' || newData.val() == 'missed' || newData.val() == 'ended' || newData.val() == 'busy'" },
        "timestamp": { ".validate": "newData.isNumber() && newData.val() <= now" },
        "duration": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)" },
        "endedBy": { ".validate": "!newData.exists() || newData.isString()" },
        "offer": { ".validate": "!newData.exists() || newData.isString()" },
        "answer": { ".validate": "!newData.exists() || newData.isString()" },
        "iceCandidates": {
          "$candidateId": { ".validate": "newData.isString()" }
        }
      }
    },

    "fcm_tokens": {
      "$userId": {
        ".read": false,
        ".write": "auth != null && auth.uid == $userId",
        "$tokenId": { ".validate": "newData.isString()" }
      }
    },

    "system_notifications": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": false,
        "$notificationId": {
          "title": { ".validate": "data.isString() && data.val().length <= 100" },
          "body": { ".validate": "data.isString() && data.val().length <= 500" },
          "timestamp": { ".validate": "data.isNumber()" },
          "read": {
            ".write": "auth != null && auth.uid == $userId",
            ".validate": "newData.isBoolean()"
          },
          "type": { ".validate": "data.isString()" },
          "data": { ".validate": "!data.exists() || data.hasChildren()" },
          "priority": { ".validate": "!data.exists() || data.val() == 'high' || data.val() == 'normal' || data.val() == 'low'" }
        }
      }
    },

    "message_reports": {
      "$reportId": {
        ".read": false,
        ".write": "auth != null && newData.child('reporterId').val() == auth.uid",
        "reporterId": { ".validate": "newData.isString() && newData.val() == auth.uid" },
        "messageId": { ".validate": "newData.isString()" },
        "chatId": { ".validate": "newData.isString()" },
        "reason": { ".validate": "newData.isString() && newData.val().matches(/^(spam|harassment|inappropriate|violence|other)$/)" },
        "description": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 500)" },
        "timestamp": { ".validate": "newData.isNumber() && newData.val() <= now" },
        "status": { ".validate": "!newData.exists() || newData.val() == 'pending'" }
      }
    },

    "broadcasts": {
      "$broadcastId": {
        ".read": "auth != null && (data.child('createdBy').val() == auth.uid || data.child('members').child(auth.uid).exists())",
        ".write": "auth != null && data.child('createdBy').val() == auth.uid",
        "id": { ".validate": "newData.isString() && newData.val() == $broadcastId" },
        "name": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 100" },
        "description": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 500)" },
        "createdBy": { ".validate": "newData.isString() && newData.val() == auth.uid" },
        "imageUrl": { ".validate": "!newData.exists() || newData.isString()" },
        "members": {
          "$memberId": { ".validate": "newData.isBoolean() && newData.val() == true" }
        },
        "createdAt": { ".validate": "newData.isNumber() && newData.val() <= now" },
        "lastMessage": { ".validate": "!newData.exists() || newData.isString()" },
        "lastMessageTimestamp": { ".validate": "!newData.exists() || newData.isNumber()" },
        "messageCount": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)" }
      }
    },

    "broadcast_messages": {
      "$broadcastId": {
        ".read": "auth != null && root.child('broadcasts').child($broadcastId).child('members').child(auth.uid).exists()",
        "$messageId": {
          ".write": "auth != null && root.child('broadcasts').child($broadcastId).child('createdBy').val() == auth.uid && newData.child('senderId').val() == auth.uid",
          "id": { ".validate": "newData.isString() && newData.val() == $messageId" },
          "senderId": { ".validate": "newData.isString() && newData.val() == auth.uid" },
          "text": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 4000)" },
          "timestamp": { ".validate": "newData.isNumber() && newData.val() <= now + 300000" },
          "type": { ".validate": "newData.isString() && newData.val().matches(/^(text|image|video|audio|document|file)$/)" },
          "deliveredTo": {
            "$userId": { ".validate": "newData.isNumber() && newData.val() <= now" }
          },
          "readBy": {
            "$userId": { ".validate": "newData.isNumber() && newData.val() <= now" }
          }
        }
      }
    }
  }
}