rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions for better readability and reusability
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isValidUser() {
      return isAuthenticated() && 
             request.auth.uid != null && 
             request.auth.uid.size() > 0;
    }
    
    // Check if user is blocked by another user
    function isBlocked(blockerId, blockedId) {
      return exists(/databases/$(database)/documents/blocked_users/$(blockerId)/blocked/$(blockedId));
    }
    
    // Check if users are friends
    function areFriends(userId1, userId2) {
      return exists(/databases/$(database)/documents/users/$(userId1)/friends/$(userId2));
    }
    
    // Validate user data structure
    function isValidUserData() {
      return request.resource.data.keys().hasAll(['name', 'email']) &&
             request.resource.data.name is string &&
             request.resource.data.email is string &&
             request.resource.data.name.size() >= 1 &&
             request.resource.data.name.size() <= 50;
    }

    // Users collection - core user profiles
    match /users/{userId} {
      // Users can read their own profile and profiles of their friends
      allow read: if isValidUser() && (
        isOwner(userId) || 
        areFriends(request.auth.uid, userId)
      );
      
      // Users can only create/update their own profile
      allow create: if isValidUser() && 
                   isOwner(userId) && 
                   isValidUserData();
      
      allow update: if isValidUser() && 
                   isOwner(userId) && 
                   isValidUserData();
      
      // Users cannot delete their profiles (use admin functions)
      allow delete: if false;

      // Friends subcollection - manage friendships
      match /friends/{friendId} {
        // Users can read their own friends list
        allow read: if isValidUser() && isOwner(userId);
        
        // Users can add/remove friends if both parties aren't blocked
        allow create, update: if isValidUser() && 
                             isOwner(userId) && 
                             !isBlocked(userId, friendId) && 
                             !isBlocked(friendId, userId);
        
        allow delete: if isValidUser() && isOwner(userId);
      }
    }

    // Status collection - user status updates (stories)
    match /status/{statusId} {
      // Users can read status from friends only
      allow read: if isValidUser() && 
                 areFriends(request.auth.uid, resource.data.userId);
      
      // Users can create their own status
      allow create: if isValidUser() && 
                   isOwner(resource.data.userId) &&
                   request.resource.data.keys().hasAll(['userId', 'timestamp', 'expiryTime']) &&
                   request.resource.data.userId == request.auth.uid;
      
      // Users can update their own status
      allow update: if isValidUser() && 
                   isOwner(resource.data.userId);
      
      // Users can delete their own status
      allow delete: if isValidUser() && 
                   isOwner(resource.data.userId);
    }

    // Blocked users collection - manage blocked relationships
    match /blocked_users/{userId} {
      // Users can only access their own blocked users list
      allow read, write: if isValidUser() && isOwner(userId);
      
      match /blocked/{blockedUserId} {
        // Users can manage their own blocked users
        allow read, write: if isValidUser() && isOwner(userId);
      }
    }

    // Presence collection - user online/offline status
    match /presence/{userId} {
      // Anyone can read presence if they're friends and user allows it
      allow read: if isValidUser() && 
                 areFriends(request.auth.uid, userId);
      
      // Users can only update their own presence
      allow write: if isValidUser() && isOwner(userId);
    }

    // User settings and preferences
    match /user_settings/{userId} {
      // Users can only read/write their own settings
      allow read, write: if isValidUser() && isOwner(userId);
    }

    // Notifications collection
    match /notifications/{userId} {
      // Users can only read their own notifications
      allow read: if isValidUser() && isOwner(userId);
      
      // System and friends can create notifications
      allow create: if isValidUser() && (
        isOwner(userId) || 
        areFriends(request.auth.uid, userId)
      );
      
      // Users can update/delete their own notifications
      allow update, delete: if isValidUser() && isOwner(userId);
    }

    // Reports collection - for reporting users/content
    match /reports/{reportId} {
      // Users can create reports
      allow create: if isValidUser() && 
                   request.resource.data.reporterId == request.auth.uid;
      
      // Users can read their own reports
      allow read: if isValidUser() && 
                 resource.data.reporterId == request.auth.uid;
      
      // No updates or deletes allowed (admin only)
      allow update, delete: if false;
    }

    // Admin collections (admin access only)
    match /admin/{document=**} {
      allow read, write: if false; // Only admin SDK can access
    }

    // Analytics and logs (system only)
    match /analytics/{document=**} {
      allow read, write: if false; // Only server can access
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}