rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions for security
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isOwner(uid) { 
      return request.auth != null && request.auth.uid == uid; 
    }
    
    function isFriend(userId) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/friends/$(userId));
    }
    
    function isNotBlocked(userId) {
      return !exists(/databases/$(database)/documents/users/$(userId)/blocked/$(request.auth.uid)) &&
             !exists(/databases/$(database)/documents/users/$(request.auth.uid)/blocked/$(userId));
    }
    
    function canReadUserBasedOnPrivacy(userId) {
      return isSignedIn() && (
        isOwner(userId) || 
        (isFriend(userId) && isNotBlocked(userId)) ||
        // Allow reading basic info for user discovery (email search)
        (!exists(/databases/$(database)/documents/users/$(userId)/blocked/$(request.auth.uid)))
      );
    }
    
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isSystemUser() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/system_users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/system_users/$(request.auth.uid)).data.role == 'system';
    }

    // Users collection - core user data
    match /users/{userId} {
      allow read: if canReadUserBasedOnPrivacy(userId);
      allow write: if isOwner(userId);
      
      // Friend requests subcollection
      match /friend_requests/{requestId} {
        allow read: if isOwner(userId) || isOwner(resource.data.fromUserId);
        allow create: if isSignedIn() && request.auth.uid != userId && isNotBlocked(userId);
        allow update, delete: if isOwner(userId);
      }
      
      // Friends subcollection with personal names
      match /friends/{friendId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      
      // Blocked users subcollection
      match /blocked/{blockedUserId} {
        allow read, write: if isOwner(userId);
      }
      
      // User settings subcollection
      match /settings/{settingId} {
        allow read, write: if isOwner(userId);
      }
      
      // Privacy settings subcollection
      match /privacy/{settingId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Global statuses collection (stories)
    match /statuses/{statusId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.userId) || 
        (isFriend(resource.data.userId) && isNotBlocked(resource.data.userId))
      );
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update: if isSignedIn() && (
        isOwner(resource.data.userId) || 
        // Allow friends to update viewers field
        (isFriend(resource.data.userId) && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewers']))
      );
      allow delete: if isOwner(resource.data.userId);
    }
    
    // User-specific statuses subcollection
    match /users/{userId}/statuses/{statusId} {
      allow read: if isSignedIn() && (
        isOwner(userId) || 
        (isFriend(userId) && isNotBlocked(userId))
      );
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && (
        isOwner(userId) || 
        // Allow friends to update viewers field
        (isFriend(userId) && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewers']))
      );
      allow delete: if isSignedIn() && isOwner(userId);
    }

    // Chat management - metadata about chats
    match /chat_management/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow delete: if isSignedIn() && request.auth.uid in resource.data.participants;
    }
    
    // Message deletion tracking - for individual message deletion
    match /message_deletions/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chat_management/$(chatId)).data.participants;
      allow write: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chat_management/$(chatId)).data.participants;
    }
    
    // Chat clearing tracking - for per-user chat clearing
    match /chat_clearing/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chat_management/$(chatId)).data.participants;
      allow write: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chat_management/$(chatId)).data.participants;
    }

    // Chat history - for message persistence (if using Firestore for messages)
    match /chat_history/{chatId} {
      allow read: if isSignedIn() && (
        request.auth.uid in get(/databases/$(database)/documents/chat_management/$(chatId)).data.participants ||
        isAdmin() ||
        isSystemUser()
      );
      allow write: if isSignedIn() && (
        request.auth.uid in get(/databases/$(database)/documents/chat_management/$(chatId)).data.participants ||
        isAdmin() ||
        isSystemUser()
      );
    }

    // Broadcast lists
    match /broadcasts/{broadcastId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.creatorId) || 
        request.auth.uid in resource.data.members
      );
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.creatorId;
      allow update: if isSignedIn() && isOwner(resource.data.creatorId);
      allow delete: if isSignedIn() && isOwner(resource.data.creatorId);
    }

    // Media files metadata (for Cloudinary references)
    match /media/{mediaId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.uploaderId) || 
        request.auth.uid in resource.data.sharedWith
      );
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.uploaderId;
      allow update: if isSignedIn() && isOwner(resource.data.uploaderId);
      allow delete: if isSignedIn() && isOwner(resource.data.uploaderId);
    }

    // Shared messages tracking
    match /shared_messages/{shareId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.senderId) || 
        request.auth.uid in resource.data.recipients
      );
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId;
      allow update: if isSignedIn() && (
        isOwner(resource.data.senderId) || 
        request.auth.uid in resource.data.recipients
      );
      allow delete: if isSignedIn() && isOwner(resource.data.senderId);
    }
    
    // Admin users collection
    match /admin_users/{adminId} {
      allow read: if isSignedIn() && (isOwner(adminId) || isAdmin());
      allow write: if isSignedIn() && isSystemUser(); // Only system users can create/modify admins
    }
    
    // System users collection
    match /system_users/{systemId} {
      allow read: if isSignedIn() && isOwner(systemId);
      allow write: if false; // No one can modify system users except Firebase Admin SDK
    }
  }
}