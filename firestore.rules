rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions for better readability and reusability
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isValidUser() {
      return isAuthenticated() && 
             request.auth.uid != null && 
             request.auth.uid.size() > 0;
    }
    
    // Check if user is blocked by another user
    function isBlocked(blockerId, blockedId) {
      return exists(/databases/$(database)/documents/users/$(blockerId)/blocked/$(blockedId));
    }
    
    // Check if users are friends
    function areFriends(userId1, userId2) {
      return exists(/databases/$(database)/documents/users/$(userId1)/friends/$(userId2));
    }
    
    // Validate user data structure
    function isValidUserData() {
      return request.resource.data.keys().hasAll(['name', 'email']) &&
             request.resource.data.name is string &&
             request.resource.data.email is string &&
             request.resource.data.name.size() >= 1 &&
             request.resource.data.name.size() <= 50;
    }
    
    // Check if user can be discovered (for friend requests)
    function canDiscoverUser(userId) {
      return isValidUser() && 
             !isBlocked(userId, request.auth.uid) && 
             !isBlocked(request.auth.uid, userId);
    }

    // Users collection - simplified structure with everything in one place
    match /users/{userId} {
      // Users can read their own profile, friends' profiles, OR for friend discovery if not blocked
      allow read: if isValidUser() && (
        isOwner(userId) || 
        areFriends(request.auth.uid, userId) ||
        canDiscoverUser(userId)
      );
      
      // Users can only create/update their own profile
      allow create: if isValidUser() && 
                   isOwner(userId) && 
                   isValidUserData();
      
      allow update: if isValidUser() && 
                   isOwner(userId) && 
                   isValidUserData();
      
      // Users cannot delete their profiles (use admin functions)
      allow delete: if false;

      // Friends subcollection - manage friendships
      match /friends/{friendId} {
        // Users can read their own friends list or if they are the friend being checked
        allow read: if isValidUser() && (isOwner(userId) || request.auth.uid == friendId);
        
        // Users can add/remove friends if both parties aren't blocked
        allow create, update: if isValidUser() && 
                             isOwner(userId) && 
                             !isBlocked(userId, friendId) && 
                             !isBlocked(friendId, userId);
        
        allow delete: if isValidUser() && isOwner(userId);
      }
      
      // Blocked users subcollection - manage blocked relationships
      match /blocked/{blockedUserId} {
        // Users can only manage their own blocked users
        allow read, write: if isValidUser() && isOwner(userId);
      }
      
      // User settings subcollection - manage preferences
      match /settings/{settingId} {
        // Users can only read/write their own settings
        allow read, write: if isValidUser() && isOwner(userId);
      }
    }

    // Messages collection - for chat functionality
    match /messages/{messageId} {
      // Users can read messages in chats they participate in and are friends
      allow read: if isValidUser() && 
                 resource.data.participants != null &&
                 resource.data.participants[request.auth.uid] == true &&
                 (
                   resource.data.senderId == request.auth.uid ||
                   (areFriends(request.auth.uid, resource.data.senderId) && 
                    !isBlocked(resource.data.senderId, request.auth.uid) &&
                    !isBlocked(request.auth.uid, resource.data.senderId))
                 );
      
      // Users can create messages in chats with friends
      allow create: if isValidUser() && 
                   request.resource.data.senderId == request.auth.uid &&
                   request.resource.data.participants != null &&
                   request.resource.data.participants[request.auth.uid] == true;
      
      // Users can update their own messages
      allow update: if isValidUser() && 
                   resource.data.senderId == request.auth.uid;
      
      // Users can delete their own messages
      allow delete: if isValidUser() && 
                   resource.data.senderId == request.auth.uid;
    }

    // Chats collection - for chat metadata
    match /chats/{chatId} {
      // Users can read chats they participate in
      allow read: if isValidUser() && 
                 resource.data.participants != null &&
                 resource.data.participants[request.auth.uid] == true;
      
      // Users can create chats with friends
      allow create: if isValidUser() && 
                   request.resource.data.participants != null &&
                   request.resource.data.participants[request.auth.uid] == true;
      
      // Users can update chats they participate in
      allow update: if isValidUser() && 
                   resource.data.participants != null &&
                   resource.data.participants[request.auth.uid] == true;
      
      // Users cannot delete chats
      allow delete: if false;
    }

    // Notifications collection
    match /notifications/{userId} {
      // Users can only read their own notifications
      allow read: if isValidUser() && isOwner(userId);
      
      // Friends can create notifications for each other
      allow create: if isValidUser() && (
        isOwner(userId) || 
        areFriends(request.auth.uid, userId)
      );
      
      // Users can update/delete their own notifications
      allow update, delete: if isValidUser() && isOwner(userId);
    }

    // Reports collection - for reporting users/content
    match /reports/{reportId} {
      // Users can create reports
      allow create: if isValidUser() && 
                   request.resource.data.reporterId == request.auth.uid;
      
      // Users can read their own reports
      allow read: if isValidUser() && 
                 resource.data.reporterId == request.auth.uid;
      
      // No updates or deletes allowed (admin only)
      allow update, delete: if false;
    }

    // Admin collections (admin access only)
    match /admin/{document=**} {
      allow read, write: if false; // Only admin SDK can access
    }

    // Analytics and logs (system only)
    match /analytics/{document=**} {
      allow read, write: if false; // Only server can access
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}