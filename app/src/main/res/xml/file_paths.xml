<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Access the external files directory for camera pictures -->
    <external-files-path
        name="my_images"
        path="Pictures" />

    <!-- Optional: Access external cache directory -->
    <external-cache-path
        name="cache"
        path="." />

    <!-- Optional: Access internal files directory -->
    <files-path
        name="internal"
        path="." />
</paths>
