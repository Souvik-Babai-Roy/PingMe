<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:gravity="end">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:maxWidth="280dp"
        android:gravity="end">

        <!-- Text Message -->
        <LinearLayout
            android:id="@+id/layoutTextMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:background="@drawable/senderchatdrawable"
            android:orientation="vertical"
            android:padding="12dp"
            android:minWidth="80dp">

            <TextView
                android:id="@+id/tvMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hello! How are you?"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:lineSpacingMultiplier="1.1"
                android:textIsSelectable="true" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12:30 PM"
                    android:textColor="@color/white_70"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp" />

                <ImageView
                    android:id="@+id/ivStatus"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_sent"
                    app:tint="@color/white_70" />

            </LinearLayout>
        </LinearLayout>

        <!-- Image Message -->
        <LinearLayout
            android:id="@+id/layoutImage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:background="@drawable/senderchatdrawable"
            android:orientation="vertical"
            android:padding="4dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivMessageImage"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:background="@color/background_color"
                android:src="@drawable/ic_image_placeholder"
                app:cornerRadius="8dp" />

            <!-- Image Caption -->
            <TextView
                android:id="@+id/tvImageCaption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="8dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvImageTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12:30 PM"
                    android:textColor="@color/white_70"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp" />

                <ImageView
                    android:id="@+id/ivImageStatus"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_sent"
                    app:tint="@color/white_70" />

            </LinearLayout>
        </LinearLayout>

        <!-- Video Message -->
        <LinearLayout
            android:id="@+id/layoutVideo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:background="@drawable/senderchatdrawable"
            android:orientation="vertical"
            android:padding="4dp"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="200dp"
                android:layout_height="200dp">

                <ImageView
                    android:id="@+id/ivVideoThumbnail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="@drawable/ic_image_placeholder"
                    android:src="@drawable/ic_video_placeholder"
                    app:cornerRadius="8dp" />

                <ImageView
                    android:id="@+id/ivPlayButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_play_circle"
                    android:background="@drawable/bg_play_button"
                    app:tint="@android:color/white" />

                <!-- Video Duration -->
                <TextView
                    android:id="@+id/tvVideoDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_video_duration"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="0:45"
                    android:textColor="@android:color/white"
                    android:textSize="12sp" />

            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvVideoTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12:30 PM"
                    android:textColor="@color/white_70"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp" />

                <ImageView
                    android:id="@+id/ivVideoStatus"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_sent"
                    app:tint="@color/white_70" />

            </LinearLayout>
        </LinearLayout>

        <!-- Audio Message -->
        <LinearLayout
            android:id="@+id/layoutAudio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:background="@drawable/senderchatdrawable"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:minWidth="200dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivPlayAudio"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_play_circle"
                android:background="@drawable/bg_play_button"
                app:tint="@color/white" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAudioDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:45"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

                <ProgressBar
                    android:id="@+id/progressAudio"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="4dp"
                    android:progress="0"
                    android:progressTint="@color/white_70" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvAudioTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12:30 PM"
                    android:textColor="@color/white_70"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp" />

                <ImageView
                    android:id="@+id/ivAudioStatus"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_sent"
                    app:tint="@color/white_70" />

            </LinearLayout>
        </LinearLayout>

        <!-- Document Message -->
        <LinearLayout
            android:id="@+id/layoutDocument"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:background="@drawable/senderchatdrawable"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:minWidth="200dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_attach"
                android:background="@drawable/bg_document_icon"
                android:padding="8dp"
                app:tint="@color/white"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDocumentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Document.pdf"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvDocumentSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.2 MB"
                    android:textColor="@color/white_70"
                    android:textSize="12sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvDocumentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12:30 PM"
                    android:textColor="@color/white_70"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp" />

                <ImageView
                    android:id="@+id/ivDocumentStatus"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_sent"
                    app:tint="@color/white_70" />

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>