<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimary"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light" />

    <!-- Loading State -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="100dp"
        android:visibility="gone" />

    <!-- Error State -->
    <LinearLayout
        android:id="@+id/errorLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_error"
            android:alpha="0.5" />

        <TextView
            android:id="@+id/tvErrorMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Failed to load profile"
            android:textSize="16sp"
            android:textColor="@color/textColorSecondary"
            android:gravity="center" />

    </LinearLayout>

    <!-- Content Layout -->
    <ScrollView
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Profile Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="24dp">

                <!-- Profile Photo -->
                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:id="@+id/ivProfilePhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/ivDefaultProfile"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/defaultprofile"
                        android:background="@drawable/circle_background"
                        android:padding="20dp" />

                </FrameLayout>

                <!-- User Name -->
                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User Name"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary"
                    android:gravity="center" />

                <!-- About -->
                <TextView
                    android:id="@+id/tvAbout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Hey there! I am using PingMe."
                    android:textSize="16sp"
                    android:textColor="@color/textColorSecondary"
                    android:gravity="center"
                    android:maxLines="3"
                    android:ellipsize="end" />

                <!-- Last Seen -->
                <TextView
                    android:id="@+id/tvLastSeen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="last seen recently"
                    android:textSize="14sp"
                    android:textColor="@color/textColorSecondary"
                    android:gravity="center" />

            </LinearLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <!-- Message Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMessage"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Message"
                    android:textSize="14sp"
                    app:icon="@drawable/ic_chat"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:cornerRadius="24dp"
                    android:backgroundTint="@color/colorPrimary" />

                <!-- Call Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCall"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:text="Call"
                    android:textSize="14sp"
                    app:icon="@drawable/ic_call"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:cornerRadius="24dp"
                    android:backgroundTint="@color/colorPrimary" />

                <!-- Video Call Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVideoCall"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Video"
                    android:textSize="14sp"
                    app:icon="@drawable/ic_videocam"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:cornerRadius="24dp"
                    android:backgroundTint="@color/colorPrimary" />

            </LinearLayout>

            <!-- User Details Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User Details"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary"
                    android:layout_marginBottom="16dp" />

                <!-- Phone Number -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_phone"
                        android:layout_marginEnd="12dp"
                        android:alpha="0.6" />

                    <TextView
                        android:id="@+id/tvPhoneNumber"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="+1234567890"
                        android:textSize="16sp"
                        android:textColor="@color/textColorPrimary" />

                </LinearLayout>

                <!-- Email -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_email"
                        android:layout_marginEnd="12dp"
                        android:alpha="0.6" />

                    <TextView
                        android:id="@+id/tvEmail"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="user@example.com"
                        android:textSize="16sp"
                        android:textColor="@color/textColorPrimary" />

                </LinearLayout>

                <!-- Joined Date -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_calendar"
                        android:layout_marginEnd="12dp"
                        android:alpha="0.6" />

                    <TextView
                        android:id="@+id/tvJoinedDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Joined Jan 2024"
                        android:textSize="16sp"
                        android:textColor="@color/textColorPrimary" />

                </LinearLayout>

            </LinearLayout>

            <!-- Block User Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBlock"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Block User"
                android:textSize="16sp"
                app:icon="@drawable/ic_block"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:cornerRadius="24dp"
                android:backgroundTint="@color/error_red"
                android:textColor="@color/white" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>